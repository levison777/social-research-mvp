PORT=8787
FIRECRAWL_API_KEY=fc-your-api-key
OPENCLI_BROWSER_CALL_LIMIT=10
# Optional: browser-visible Link/comment collection engine.
# opencli keeps the existing shared-browser behavior.
# auto tries CloakBrowser first, then falls back to opencli.
# cloak forces CloakBrowser and fails if it is unavailable.
BROWSER_ENGINE=opencli
CLOAKBROWSER_HEADLESS=true
CLOAKBROWSER_HUMANIZE=true
CLOAKBROWSER_GEOIP=false
CLOAKBROWSER_HUMAN_PRESET=careful
CLOAKBROWSER_TIMEZONE=Asia/Shanghai
CLOAKBROWSER_LOCALE=zh-CN
CLOAKBROWSER_COST_PER_CALL=0
CLOAKBROWSER_CURRENCY=USD
# CLOAKBROWSER_PROFILE_DIR=.cloakbrowser/profiles/default
# CLOAKBROWSER_PROXY=http://user:pass@proxy:8080
# CLOAKBROWSER_FINGERPRINT=social-research-default
# Optional: point to a self-hosted Firecrawl deployment instead of the cloud API.
# FIRECRAWL_BASE_URL=https://your-firecrawl-host/v2
# Optional: estimated unit costs used for the frontend cost dashboard.
FIRECRAWL_COST_PER_CALL=0
APIFY_API_TOKEN=apify_api_your-token
APIFY_COST_PER_CALL=0
APIFY_CURRENCY=USD
# Optional: Apify API v2 base used for connection tests and actor calls.
# APIFY_BASE_URL=https://api.apify.com/v2
# Optional: TikTok keyword collection via Apify actor.
APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_TIKTOK_MAX_RESULTS=5
APIFY_TIKTOK_USE_PROXY=true
APIFY_TIKTOK_COST_PER_1000_RESULTS=1.70
# Optional: LinkedIn target-link comment collection via Apify actor.
APIFY_LINKEDIN_COMMENTS_ACTOR=harvestapi/linkedin-post-comments
APIFY_LINKEDIN_COMMENTS_COST_PER_1000_RESULTS=2.00
TIKHUB_API_KEY=tikhub_your-token
TIKHUB_COST_PER_CALL=0.001
TIKHUB_MAX_COST_PER_CALL=0.01
TIKHUB_CURRENCY=USD
# Optional: for Mainland China network, TikHub docs recommend https://api.tikhub.dev
# TIKHUB_BASE_URL=https://api.tikhub.dev
XAPI_API_KEY=sk-your-xapi-key
XAPI_COST_PER_CALL=0
XAPI_CURRENCY=USD
XAPI_DEFAULT_CU_PER_CALL=0
XAPI_COST_PER_CU=0
# Optional: XAPI account API base used for connection tests and provider metadata.
# XAPI_BASE_URL=https://api.xapi.to/api
# Optional: OpenAI-compatible LLM used by /api/agent/plan.
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_ENDPOINT=/chat/completions
LLM_JSON_MODE=true
LLM_COST_PER_1K_INPUT=0
LLM_COST_PER_1K_OUTPUT=0
LLM_COST_PER_CALL=0
# Optional: JSON array/object matching social-research-mvp.api-providers.example.json.
# SOCIAL_RESEARCH_API_PROVIDERS='{"providers":[{"id":"custom-api","name":"Custom API","baseUrl":"https://api.example.com","apiKeyEnv":"CUSTOM_API_KEY","costPerCall":0.001}]}'
