HOST=127.0.0.1
PORT=8787
SOCIAL_RESEARCH_DATABASE_PATH=data/social-research.sqlite3

# The first registered @cometsgame.com account becomes an administrator.
# Disable registration after the initial administrator is created.
AUTH_ALLOW_REGISTRATION=true
AUTH_SESSION_DAYS=7
# Optional: pin the super administrator to one active admin email.
# When omitted, the earliest active administrator is used.
SUPER_ADMIN_EMAIL=first-admin@cometsgame.com

# API-first collection with OpenCLI browser capability enabled for account collection.
API_ONLY_COLLECTION=false
KEYWORD_PROVIDER_STRATEGY=api-first
KEYWORD_API_FALLBACK=true
MONITOR_INTERVAL_MINUTES=30

# OpenCLI / Chrome Browser Bridge
BROWSER_ENGINE=opencli
OPENCLI_BIN=opencli
OPENCLI_BROWSER_SESSION=social-research-mvp
OPENCLI_BROWSER_WINDOW=foreground
OPENCLI_BROWSER_CALL_LIMIT=10

# TikHub
TIKHUB_API_KEY=tikhub_your-token
# TIKHUB_BASE_URL=https://api.tikhub.dev
TIKHUB_COST_PER_CALL=0.001
TIKHUB_MAX_COST_PER_CALL=0.01
TIKHUB_CURRENCY=USD

# Apify
APIFY_API_TOKEN=apify_api_your-token
# APIFY_BASE_URL=https://api.apify.com/v2
APIFY_CURRENCY=USD
APIFY_COST_PER_CALL=0

APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
APIFY_GOOGLE_FULL_ARTICLE_ACTOR=ohmydata/google-search-to-full-article
APIFY_LINKEDIN_POST_SEARCH_ACTOR=harvestapi/linkedin-post-search
APIFY_LINKEDIN_COMMENTS_ACTOR=harvestapi/linkedin-post-comments
APIFY_INSTAGRAM_HASHTAG_ACTOR=apidojo/instagram-hashtag-scraper
APIFY_FACEBOOK_POST_SEARCH_ACTOR=powerai/facebook-post-search-scraper
APIFY_FACEBOOK_COMMENTS_ACTOR=apify/facebook-comments-scraper
APIFY_REDDIT_COMMENTS_ACTOR=crawlerbros/reddit-comment-scraper
APIFY_WEBSITE_CONTENT_ACTOR=apify/website-content-crawler

APIFY_TIKTOK_MAX_RESULTS=5
APIFY_GOOGLE_KEYWORD_MAX_RESULTS=10
APIFY_LINKEDIN_KEYWORD_MAX_RESULTS=5
APIFY_SOCIAL_KEYWORD_MAX_RESULTS=5
APIFY_TIKTOK_USE_PROXY=true
APIFY_TIKTOK_COST_PER_1000_RESULTS=1.70
APIFY_LINKEDIN_COMMENTS_COST_PER_1000_RESULTS=2.00

# Optional OpenAI-compatible LLM for the collection-plan agent.
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-model-name
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_ENDPOINT=/chat/completions
LLM_JSON_MODE=true
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_MS=45000
LLM_COST_PER_1K_INPUT=0
LLM_COST_PER_1K_OUTPUT=0
LLM_COST_PER_CALL=0
